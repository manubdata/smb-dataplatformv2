    create  table
      "dbt_metrics"."main"."int_daily_ad_spend__dbt_tmp"
  
    as (
      

with meta_spend as (
    select
        date_day,
        'Meta' as platform,
        spend
    from "dbt_metrics"."main"."stg_meta_ads"
),
tiktok_spend as (
