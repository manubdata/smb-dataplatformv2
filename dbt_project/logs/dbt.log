        'TikTok' as platform,
        spend
    from "dbt_metrics"."main"."stg_tiktok_ads"
),
unioned_spend as (
    select * from meta_spend
    union all
    select * from tiktok_spend
)
select
    date_day,
    sum(spend) as total_ad_spend,
    sum(case when platform = 'Meta' then spend else 0 end) as meta_spend,
    sum(case when platform = 'TikTok' then spend else 0 end) as tiktok_spend
from unioned_spend
group by 1
    );
  
  
