    create  table
      "dbt_metrics"."main"."int_daily_orders__dbt_tmp"
  
    as (
      

with orders as (
    select * from "dbt_metrics"."main"."stg_orders"
),
orders_with_json as (
    select 
        *,
        from_json(line_items, 'STRUCT(id BIGINT, product_id BIGINT, title VARCHAR, quantity BIGINT, price DOUBLE)[]') as line_items_json
    from orders
),
orders_unioned as (
    select
        *,
        unnest(line_items_json) as line_item
