tarted_at": "2026-01-07T19:40:36.762514Z", "completed_at": "2026-01-07T19:40:36.768514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.011000394821166992, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.smb_dataplatform.not_null_stg_tiktok_ads_date_day.29eb2a8136", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect date_day\nfrom \"dbt_metrics\".\"main\".\"stg_tiktok_ads\"\nwhere date_day is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.772514Z", "completed_at": "2026-01-07T19:40:36.776514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.776514Z", "completed_at": "2026-01-07T19:40:36.898514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.1270003318786621, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.int_daily_orders", "compiled": true, "compiled_code": "\n\nwith orders as (\n    select * from \"dbt_metrics\".\"main\".\"stg_orders\"\n),\ncustomer_order_rank as (\n    select\n        order_id,\n        customer_id,\n        order_date,\n        rank() over (partition by customer_id order by order_date, order_id) as customer_order_rank\n    from orders\n),\norders_with_rank as (\n    select\n        o.*,\n        cor.customer_order_rank\n    from orders o\n    join customer_order_rank cor on o.order_id = cor.order_id\n)\nselect\n    order_date as date_day,\n    product_id,\n    product_title,\n\n    sum(net_sales) as total_net_sales,\n    sum(cogs) as total_cogs,\n    sum(shipping_cost) as total_shipping_cost,\n    sum(transaction_fee) as total_transaction_fee,\n    sum(total_discounts) as total_discounts,\n    \n    sum(product_price * product_quantity) as product_revenue,\n    sum(product_price * product_quantity * 0.5) as product_cogs, -- Mock COGS\n    sum(product_quantity) as product_quantity,\n\n    count(distinct order_id) as total_orders,\n    count(case when customer_order_rank = 1 then order_id end) as first_time_orders,\n    count(distinct customer_id) as total_customers\nfrom orders_with_rank\ngroup by 1,2,3", "relation_name": "\"dbt_metrics\".\"main\".\"int_daily_orders\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.902514Z", "completed_at": "2026-01-07T19:40:36.905514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.906514Z", "completed_at": "2026-01-07T19:40:36.936514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.03500008583068848, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.int_daily_ad_spend", "compiled": true, "compiled_code": "\n\nwith meta_insights as (\n    select\n        date_day,\n        spend,\n        publisher_platform\n    from \"dbt_metrics\".\"main\".\"stg_meta_ads\"\n),\ntiktok_spend as (\n    select\n        date_day,\n        spend\n    from \"dbt_metrics\".\"main\".\"stg_tiktok_ads\"\n),\ndaily_meta_platform_spend as (\n    select\n        date_day,\n        sum(case when lower(publisher_platform) = 'facebook' then spend else 0 end) as facebook_spend,\n        sum(case when lower(publisher_platform) = 'instagram' then spend else 0 end) as instagram_spend,\n        sum(spend) as meta_total_spend\n    from meta_insights\n    group by 1\n)\nselect\n    coalesce(dmp.date_day, ts.date_day) as date_day,\n    coalesce(dmp.meta_total_spend, 0) + coalesce(ts.spend, 0) as total_ad_spend,\n    coalesce(dmp.facebook_spend, 0) as facebook_spend,\n    coalesce(dmp.instagram_spend, 0) as instagram_spend,\n    coalesce(ts.spend, 0) as tiktok_spend\nfrom daily_meta_platform_spend dmp\nfull outer join tiktok_spend ts on dmp.date_day = ts.date_day", "relation_name": "\"dbt_metrics\".\"main\".\"int_daily_ad_spend\"", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "20