form.not_null_stg_tiktok_ads_date_day.29eb2a8136", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect date_day\nfrom \"dbt_metrics\".\"main\".\"stg_tiktok_ads\"\nwhere date_day is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2025-12-29T17:22:57.519774Z", "completed_at": "2025-12-29T17:22:57.521774Z"}, {"name": "execute", "started_at": "2025-12-29T17:22:57.521774Z", "completed_at": "2025-12-29T17:22:57.578776Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.06000018119812012, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.int_daily_orders", "compiled": true, "compiled_code": "\n\nwith orders as (\n    select * from \"dbt_metrics\".\"main\".\"stg_orders\"\n),\ncustomer_order_rank as (\n    select\n        order_id,\n        customer_id,\n        order_date,\n        rank() over (partition by customer_id order by order_date, order_id) as customer_order_rank\n    from orders\n),\norders_with_rank as (\n    select\n        o.*,\n        cor.customer_order_rank\n    from orders o\n    join customer_order_rank cor on o.order_id = cor.order_id\n)\nselect\n    order_date as date_day,\n    sum(net_sales) as total_net_sales,\n    sum(cogs) as total_cogs,\n    sum(shipping_cost) as total_shipping_cost,\n    sum(transaction_fee) as total_transaction_fee,\n    count(order_id) as total_orders,\n    count(case when customer_order_rank = 1 then order_id end) as first_time_orders,\n    count(distinct customer_id) as total_customers\nfrom orders_with_rank\ngroup by 1", "relation_name": "\"dbt_metrics\".\"main\".\"int_daily_orders\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2025-12-29T17:22:57.582773Z", "completed_at": "2025-12-29T17:22:57.585773Z"}, {"name": "execute", "started_at": "2025-12-29T17:22:57.585773Z", "completed_at": "2025-12-29T17:22:57.616772Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.03499865531921387, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.int_daily_ad_spend", "compiled": true, "compiled_code": "\n\nwith meta_insights as (\n    select\n        date_day,\n        spend,\n        publisher_platform\n    from \"dbt_metrics\".\"main\".\"stg_meta_ads\"\n),\ntiktok_spend as (\n    select\n        date_day,\n        spend\n    from \"dbt_metrics\".\"main\".\"stg_tiktok_ads\"\n),\ndaily_meta_platform_spend as (\n    select\n        date_day,\n        sum(case when lower(publisher_platform) = 'facebook' then spend else 0 end) as facebook_spend,\n        sum(case when lower(publisher_platform) = 'instagram' then spend else 0 end) as instagram_spend,\n        sum(spend) as meta_total_spend\n    from meta_insights\n    group by 1\n)\nselect\n    coalesce(dmp.date_day, ts.date_day) as date_day,\n    coalesce(dmp.meta_total_spend, 0) + coalesce(ts.spend, 0) as total_ad_spend,\n    coalesce(dmp.facebook_spend, 0) as facebook_spend,\n    coalesce(dmp.instagram_spend, 0) as instagram_spend,\n    coalesce(ts.spend, 0) as tiktok_spend\nfrom daily_meta_platform_spend dmp\nfull outer join tiktok_spend ts on dmp.date_day = ts.date_day", "relation_name": "\"dbt_metrics\".\"main\".\"int_daily_ad_spend\"", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2025-12-29T17:22:57.620777Z", "completed_at": "2025-12-29T17:22:57.623775Z"}, {"name": "execute", "started_at": "2025-12-29T17:22:57.623775Z", "completed_at": "2025-12-29T17:22:57.629778Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.010999917984008789, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.smb_dataplatform.not_null_int_daily_orders_date_day.f1bdc1c94e", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect date_day\nfrom \"dbt_metrics\".\"main\".\"int_daily_orders\"\nwhere date_day is n