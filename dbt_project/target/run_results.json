a\".\"orders\"\n)\n\nselect\n    id as order_id,\n    customer__id as customer_id,\n    cast(created_at as date) as order_date,\n    cast(total_price as numeric(38, 2)) as net_sales,\n    \n    -- Mock COGS as 50% of net sales. In a real scenario, this would come from\n    -- product cost data.\n    cast(total_price as numeric(38, 2)) * 0.50 as cogs,\n    \n    -- Extracting shipping cost from the nested field.\n    cast(total_shipping_price_set__shop_money__amount as numeric(38, 2)) as shipping_cost,\n    \n    -- Transaction Fee is a placeholder. This often comes from a separate\n    -- payment gateway source (e.g., Stripe, Shopify Payments).\n    0 as transaction_fee\n\nfrom source", "relation_name": "\"dbt_metrics\".\"main\".\"stg_orders\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2025-12-29T17:22:57.292772Z", "completed_at": "2025-12-29T17:22:57.295772Z"}, {"name": "execute", "started_at": "2025-12-29T17:22:57.296775Z", "completed_at": "2025-12-29T17:22:57.316772Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.024998903274536133, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.stg_tiktok_ads", "compiled": true, "compiled_code": "-- Silver Layer (staging) for TikTok Ads\n-- This model cleans and prepares raw ad spend data from the bronze layer.\n\nwith source as (\n    -- This should point to your raw tiktok ads data in the bronze layer\n    select\n        cast(stat_time_day as date) as date_day,\n        spend\n    from \"tiktok_db\".\"main\".\"ad_reports\"\n)\n\nselect\n    date_day,\n    sum(spend) as spend -- Aggregate spend by date_day to ensure uniqueness\nfrom source\ngroup by 1", "relation_name": "\"dbt_metrics\".\"main\".\"stg_tiktok_ads\"", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2025-12-29T17:22:57.320777Z", "completed_at": "2025-12-29T17:22:57.328773Z"}, {"name": "execute", "s