{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.10.17", "generated_at": "2026-01-07T19:40:37.256514Z", "invocation_id": "6cfe179b-73ee-46b6-a42a-78031cdc9dde", "invocation_started_at": "2026-01-07T19:40:35.262515Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.471514Z", "completed_at": "2026-01-07T19:40:36.476514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.477514Z", "completed_at": "2026-01-07T19:40:36.526514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.055999755859375, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.stg_meta_ads", "compiled": true, "compiled_code": "-- Silver Layer (staging) for Meta Ads\n-- This model cleans and prepares raw ad spend data from the bronze layer.\n\nwith source as (\n    -- This should point to your raw meta ads data in the bronze layer\n    select * from \"facebook_db\".\"main\".\"ads_insights\"\n)\n\nselect\n    cast(date_start as date) as date_day,\n    spend,\n    publisher_platform\nfrom source", "relation_name": "\"dbt_metrics\".\"main\".\"stg_meta_ads\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.531514Z", "completed_at": "2026-01-07T19:40:36.533514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.534514Z", "completed_at": "2026-01-07T19:40:36.553514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.02399897575378418, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.stg_orders", "compiled": true, "compiled_code": "-- Silver Layer (staging) for Orders\n-- This model cleans and prepares raw order data from the bronze layer.\n\nwith source as (\n    -- This should point to your raw orders data in the bronze layer\n    select * from \"shopify_db\".\"shopify_data\".\"orders\"\n)\n\nselect\n    id as order_id,\n    customer__id as customer_id,\n    cast(created_at as date) as order_date,\n    financial_status,\n\n    -- Net Sales is total price minus discounts.\n    cast(total_price as numeric) - cast(total_discounts as numeric) as net_sales,\n    \n    -- Mock COGS as 50% of net sales. In a real scenario, this would come from\n    -- product cost data.\n    cast(total_line_items_price as numeric) * 0.50 as cogs,\n    \n    -- Extracting shipping cost from the nested field.\n    cast(total_shipping_price_set__shop_money__amount as numeric) as shipping_cost,\n\n    cast(total_discounts as numeric) as total_discounts,\n    \n    -- Transaction Fee is a placeholder. This often comes from a separate\n    -- payment gateway source (e.g., Stripe, Shopify Payments).\n    0 as transaction_fee,\n\n    total_line_items_price,\n\n    product_id,\n    product_title,\n    product_quantity,\n    product_price\n\nfrom source", "relation_name": "\"dbt_metrics\".\"main\".\"stg_orders\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.557514Z", "completed_at": "2026-01-07T19:40:36.559514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.560517Z", "completed_at": "2026-01-07T19:40:36.580514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.025002241134643555, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.smb_dataplatform.stg_tiktok_ads", "compiled": true, "compiled_code": "-- Silver Layer (staging) for TikTok Ads\n-- This model cleans and prepares raw ad spend data from the bronze layer.\n\nwith source as (\n    -- This should point to your raw tiktok ads data in the bronze layer\n    select\n        cast(stat_time_day as date) as date_day,\n        spend\n    from \"tiktok_db\".\"main\".\"ad_reports\"\n)\n\nselect\n    date_day,\n    sum(spend) as spend -- Aggregate spend by date_day to ensure uniqueness\nfrom source\ngroup by 1", "relation_name": "\"dbt_metrics\".\"main\".\"stg_tiktok_ads\"", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.584514Z", "completed_at": "2026-01-07T19:40:36.592514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.592514Z", "completed_at": "2026-01-07T19:40:36.610514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.02899932861328125, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.smb_dataplatform.accepted_values_stg_meta_ads_publisher_platform__facebook__instagram.0fbad0e320", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        publisher_platform as value_field,\n        count(*) as n_records\n\n    from \"dbt_metrics\".\"main\".\"stg_meta_ads\"\n    group by publisher_platform\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'facebook','instagram'\n)\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.615514Z", "completed_at": "2026-01-07T19:40:36.618514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.619514Z", "completed_at": "2026-01-07T19:40:36.625514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.011999845504760742, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.smb_dataplatform.not_negative_stg_meta_ads_spend.b18b464204", "compiled": true, "compiled_code": "\n\nselect *\nfrom \"dbt_metrics\".\"main\".\"stg_meta_ads\"\nwhere spend < 0\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-01-07T19:40:36.628514Z", "completed_at": "2026-01-07T19:40:36.633514Z"}, {"name": "execute", "started_at": "2026-01-07T19:40:36.634514Z", "completed_at": "2026-01-07T19:40:36.640514Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.01300072669982910