tform.int_daily_ad_spend", "compiled": true, "compiled_code": "\n\nwith meta_insights as (\n    select\n        date_day,\n        spend,\n        publisher_platform\n    from `smb-dataplatform`.`smb_dataplatform`.`stg_meta_ads`\n),\ntiktok_spend as (\n    select\n        date_day,\n        spend\n    from `smb-dataplatform`.`smb_dataplatform`.`stg_tiktok_ads`\n),\ndaily_meta_platform_spend as (\n    select\n        date_day,\n        sum(case when lower(publisher_platform) = 'facebook' then spend else 0 end) as facebook_spend,\n        sum(case when lower(publisher_platform) = 'instagram' then spend else 0 end) as instagram_spend,\n        sum(spend) as meta_total_spend\n    from meta_insights\n    group by 1\n)\nselect\n    coalesce(dmp.date_day, ts.date_day) as date_day,\n    coalesce(dmp.meta_total_spend, 0) + coalesce(ts.spend, 0) as total_ad_spend,\n    coalesce(dmp.facebook_spend, 0) as facebook_spend,\n    coalesce(dmp.instagram_spend, 0) as instagram_spend,\n    coalesce(ts.spend, 0) as tiktok_spend\nfrom daily_meta_platform_spend dmp\nfull outer join tiktok_spend ts on dmp.date_day = ts.date_day", "relation_name": "`smb-dataplatform`.`smb_dataplatform`.`int_daily_ad_spend`", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-01-05T15:29:33.635140Z", "completed_at": "2026-01-05T15:29:33.646201Z"}, {"name": "execute", "started_at": "2026-01-05T15:29:33.647203Z", "completed_at": "2026-01-05T15:29:35.473161Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 1.8420233726501465, "adapter_response": {"_message": "SELECT (1.0 rows, 240.0 Bytes processed)", "code": "SELECT", "rows_affected": 1, "bytes_processed": 240, "bytes_billed": 10485760, "location": "US", "project_id": "smb-dataplatform", "job_id": "5e67fe86-fa6b-4ef6-af88-d4c36aa368e5", "slot_ms": 18}, "message": null, "failures": 0, "unique_id": "test.smb_dataplatform.not_negative_int_daily_ad_spend_facebook_spend.9cd770ed27", "compiled": true, "compiled_code