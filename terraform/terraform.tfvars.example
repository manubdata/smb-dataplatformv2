# Google Cloud Settings
gcp_project_id = "your-gcp-project-id"
gcp_region     = "us-central1"

# Client-Specific Settings
client_name    = "acme-corp" # A unique name for the client, e.g., 'acme-corp'. Used as a prefix for resources.

# Secret Manager Secret Names
# These are the names of the secrets as they exist in Google Secret Manager.
shopify_shop_url_secret_name      = "shop_url"
shopify_client_id_secret_name     = "client_id"
shopify_client_secret_secret_name = "client_secret"
